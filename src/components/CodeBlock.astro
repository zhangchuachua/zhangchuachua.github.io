---
interface Props {
    class?: string;
    style?: string | astroHTML.JSX.CSSProperties | null;
    tabindex: string;
    [key: `data-${string}`]: any;
}

// TODO 实现代码折叠
const isLongCode =  Astro.props?.['data-code-length'] > 20;
---

<pre {...Astro.props} data-too-long={isLongCode}>
<slot />
</pre>
