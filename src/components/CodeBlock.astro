<style>
    .code-block-wrapper {
        position: relative;
    }

    .long-code {
        max-height: 400px;
        overflow: hidden;
        transition: max-height 0.3s ease-in-out;
    }

    .long-code.collapsed {
        position: relative;
    }

    .long-code.collapsed::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 60px;
        background: linear-gradient(transparent, rgb(var(--color-bg-main)));
        pointer-events: none;
    }

    .expand-button {
        position: absolute;
        bottom: 0;
        left: 50%;
        transform: translateX(-50%);
        background-color: rgb(var(--color-bg-muted));
        border: 1px solid rgb(var(--color-border-main));
        color: rgb(var(--color-text-main));
        padding: 4px 12px;
        border-radius: 4px;
        cursor: pointer;
        z-index: 1;
    }

    .expand-button:hover {
        background-color: rgb(var(--color-bg-main));
    }

    .collapse-text {
        display: none;
    }

    .long-code:not(.collapsed) + .expand-button .expand-text {
        display: none;
    }

    .long-code:not(.collapsed) + .expand-button .collapse-text {
        display: inline;
    }

    .long-code:not(.collapsed) {
        max-height: none;
    }
</style>

<script>
    document.addEventListener('astro:page-load', () => {
        const buttons = document.querySelectorAll('.expand-button');
        buttons.forEach((button) => {
            button.addEventListener('click', () => {
                const wrapper = button.closest('.code-block-wrapper');
                const pre = wrapper?.querySelector('pre');
                if (pre?.classList.contains('long-code')) {
                    pre.classList.toggle('collapsed');
                }
            });
        });
    });
</script>
